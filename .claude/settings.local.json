{
  "permissions": {
    "allow": [
      "Bash(grep -r \"error!\\\\|warn!\\\\|log\\\\|debug\\\\|panic\" crates/ghostty-app/src/terminal/*.rs)"
    ]
  }
}
{
   "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_SPAWN_BACKEND": "tmux"
   },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "effortLevel": "max",
  "includeCoAuthoredBy": false,
  "teammateMode": "tmux",
  "spawnBackend": "direct-tmux"
}